{
  "analyzers_all": ["cppcheck", "frama-c", "splint", "infer", "flawfinder", "rats"],
  "tests": [
    {
      "name": "Buffer Overflow (CWE 120)",
      "path": "tests/sa-tests-db/basic_set/c/3-buffer-overflow",
      "cwe": 120,
      "analyzers": {

        "cppcheck": {
          "accepted_errors": [
            "arrayIndexOutOfBounds",
            "bufferAccessOutOfBounds",
            "outOfBounds"
          ],
          "accepted_cwe": [120, 787, 788]
        },

        "frama-c": {
          "accepted_errors": [
            "out of bounds",
            "invalid memory access"
          ],
          "accepted_cwe": [120, 787, 788]
        },

        "splint": {
          "accepted_errors": [
            "Likely buffer overflow",
            "Out of bounds array access",
            "out-of-bounds"
          ],
          "accepted_cwe": [120, 787, 788]
        },

        "infer": {
          "accepted_errors": [
            "BUFFER_OVERRUN_L1",
            "BUFFER_OVERRUN_L2",
            "Out of bounds write"
          ],
          "accepted_cwe": [120, 787, 788]
        },

        "flawfinder": {
          "accepted_errors": [
            "buffer overflow",
            "potential overflows",
            "buffer overflows",
            "CWE-120",
            "buffer overflow"
          ],
          "accepted_cwe": [120]
        },

        "rats": {
          "accepted_errors": [
            "buffer overflow",
            "memset",
            "High risk: memset"
          ],
          "accepted_cwe": [120]
        }
      }
    },
    {
